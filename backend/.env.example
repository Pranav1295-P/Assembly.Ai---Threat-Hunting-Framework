# =====================================================================
# Assembly.AI — Provider configuration
#
# Pick AT LEAST ONE provider below and fill in the key/base URL.
# Priority is: LLM_PROVIDER (if set) → first matching key in the list.
# =====================================================================

# Optional explicit pick: anthropic | openai | groq | openrouter | together | ollama | heuristic
LLM_PROVIDER=

# ----- 1. Groq  (RECOMMENDED FREE OPTION — very fast Llama 3.3 70B) -----
# Sign up at https://console.groq.com and create a key starting with "gsk_".
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# alternatives: llama-3.1-8b-instant, mixtral-8x7b-32768, gemma2-9b-it

# ----- 2. OpenRouter  (FREE tier — Llama/Mistral free variants) ---------
# Sign up at https://openrouter.ai. Key starts with "sk-or-".
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
# alternatives: mistralai/mistral-7b-instruct:free, google/gemma-2-9b-it:free

# ----- 3. Together AI  (Free tier with $25 credits + free Llama Turbo) -
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free

# ----- 4. Ollama  (FREE — runs locally, no key, no internet) -----------
# 1) Install Ollama from https://ollama.com
# 2) `ollama pull llama3.1:8b`  (or mistral, qwen2.5, etc.)
# 3) Set the URL below; that is enough for Assembly.AI to use it.
OLLAMA_BASE_URL=
# typical value: http://127.0.0.1:11434/v1
OLLAMA_MODEL=llama3.1:8b

# ----- 5. Anthropic Claude  (paid, but high quality — original Garuda demo)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ----- 6. OpenAI / Azure / any OpenAI-compatible endpoint --------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# leave blank for api.openai.com; set for Azure/etc.
OPENAI_BASE_URL=

# =====================================================================
# Server
# =====================================================================
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=0
MAX_UPLOAD_MB=64

# =====================================================================
# Database (PostgreSQL)
# Format:  postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
#
# Quick docker setup:
#   docker run -d --name aisecops-pg \
#       -e POSTGRES_USER=aisecops \
#       -e POSTGRES_PASSWORD=aisecops \
#       -e POSTGRES_DB=aisecops \
#       -p 5432:5432 postgres:16
#
# Or via Homebrew (macOS):
#   brew install postgresql@16 && brew services start postgresql@16
#   createuser -s aisecops && createdb aisecops -O aisecops
# =====================================================================
DATABASE_URL=postgresql+psycopg2://aisecops:aisecops@localhost:5432/aisecops

# Set to 1 to fall back to a local SQLite file if Postgres is unreachable.
# Useful for first-run smoke tests.
DB_ALLOW_SQLITE_FALLBACK=1
